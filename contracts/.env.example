# Used by `forge script script/DeployBatchTokenTransfer.s.sol ...`.
# Forge auto-loads this file from contracts/ — never commit a real key.
PRIVATE_KEY=

# One RPC URL per chain; referenced via foundry.toml's [rpc_endpoints] and
# also usable directly as --rpc-url "$ETHEREUM_RPC_URL" per the README.
ETHEREUM_RPC_URL=
BASE_RPC_URL=
BSC_RPC_URL=

# Etherscan API v2 key (https://etherscan.io/apis). A single key now verifies
# on Etherscan, Basescan, and Bscscan via chain id — see foundry.toml
# [etherscan]. If your forge predates the v2 key consolidation and rejects
# this, fall back to BASESCAN_API_KEY / BSCSCAN_API_KEY and adjust
# foundry.toml's [etherscan] block accordingly.
ETHERSCAN_API_KEY=
