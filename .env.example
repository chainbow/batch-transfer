# Optional RPC overrides for the browser wallet client (src/wagmi.ts).
# The app ships with public CORS-safe fallback RPCs per chain, so these are
# only needed to use a private/paid RPC provider in production.
VITE_ETHEREUM_RPC_URL=
VITE_BASE_RPC_URL=
VITE_BSC_RPC_URL=

# Optional batch-transfer contract address overrides (src/config.ts), keyed
# by chain id. Ethereum (1) and Base (8453) fall back to the addresses
# hardcoded in src/config.ts. BSC (56) has no fallback yet — the contract
# has not been deployed there. Set it after running the deploy script (see
# README) to enable batch transfers on BNB Smart Chain.
VITE_BATCH_TRANSFER_CONTRACT_1=
VITE_BATCH_TRANSFER_CONTRACT_8453=
VITE_BATCH_TRANSFER_CONTRACT_56=
